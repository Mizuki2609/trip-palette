
<h3>新規投稿ページ</h3>
<%= form_for @tweet, html: { multipart: true } do |f| %>

  <div class="field">
    <%= f.label :recommended_spot %>
    <%= f.text_field :name, :size => 30 %>
  </div>


  <div class="field">
    <%= f.label :adress  %>
  <%= f.text_field :adress, size: 30 %> 
  </div>

  <div class="field">
    <%= f.label :time  %>
    <%= f.text_field :time, :size => 30 %>
  </div>

  <div class="field">
    <%= f.label :cost  %>
    <%= f.number_field :cost %>
  </div>

  <div class="field">
    <%= f.label :point  %>
    <%= f.text_area :point, :size => "30x2" %>
  </div>

  <div class="field">
    <%= f.label :image  %>
    <%= f.file_field :image %>
  </div>

  <%= f.submit "投稿する" %>
<% end %>

<%= link_to "一覧に戻る", tweets_path %>