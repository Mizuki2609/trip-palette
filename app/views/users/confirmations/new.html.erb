<style>
  .login-wrapper {
    background-color: #fdf6f7; 
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .login-card {
    background: white;
    padding: 40px;
    border-radius: 20px; 
    border: 4px solid #000; 
    text-align: center;
    width: 380px;
    box-sizing: border-box;
  }

  .login-card h2 {
    color: #000;
    font-size: 1.8rem;
    font-weight: bold;
    margin-bottom: 20px;
    text-align: center;
  }

  .field {
    margin-bottom: 20px;
  }

  .field p {
    margin-bottom: 5px;
  }

  .input-field {
    width: 100% !important;
    max-width: 280px;
    box-sizing: border-box;
    padding: 12px;
    border: 3px solid #000;
    border-radius: 15px;
    display: inline-block;
  }

  .field-remember {
    margin-bottom: 20px;
    font-weight: bold;
  }

  .login-button {
    background: #ee87c8;
    color: white;
    border: none;
    padding: 12px 60px;
    border-radius: 30px;
    font-weight: bold;
    font-size: 1.1rem;
    cursor: pointer;
    margin-bottom: 10px;
  }

  .shared-links {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .shared-links a {
    display: block;
    color: #000;
    font-weight: bold;
    text-decoration: none;
    margin-top: 10px;
    font-family: inherit;
  }
</style>

<div class="login-wrapper">
  <div class="login-card">

    <h2>log in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      
      <div class="field">
        <p><strong>e-mail</strong></p>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-field" %>
      </div>

      <div class="field">
        <p><strong>password</strong></p>
        <%= f.password_field :password, autocomplete: "current-password", class: "input-field" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="field-remember">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "remember me" %>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "log in", class: "login-button" %>
      </div>

    <% end %>

    <div class="shared-links">
      <%= render "users/shared/links" %>
    </div>

  </div>
</div>



